# Streamlit Cloud Secrets Template
# Copia este archivo como secrets.toml (sin .template)
# y configura tus credenciales de Turso.

# Para obtener las credenciales:
# 1. Crea cuenta gratis en https://turso.tech
# 2. Crea una base de datos (ej: "gametronix")
# 3. Ve al dashboard → Databases → tu-db → "Get Token"
# 4. Copia la URL y el token aquí

TURSO_DB_URL = "libsql://tu-base-de-datos.turso.io"
TURSO_AUTH_TOKEN = "tu-token-de-acceso-aqui"
